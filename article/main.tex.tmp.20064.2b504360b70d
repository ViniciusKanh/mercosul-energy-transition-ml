\label{tab:importancia-variaveis}
\begin{tabular}{lc}
\toprule
\textbf{Variável} & \textbf{Importância média} \\
\midrule
Tendência de renováveis (5 anos) & 0,107 \\
Participação de renováveis (eletricidade) & 0,099 \\
Participação fóssil (eletricidade) & 0,095 \\
Baixo carbono (eletricidade) & 0,095 \\
Participação fóssil (energia) & 0,094 \\
